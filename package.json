{
  "name": "smartnotes",
  "version": "0.1.0",
  "private": true,
  "description": "SmartNotes Fullstack - personal notes app (NestJS + Next.js monorepo)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:api": "pnpm --filter @smartnotes/api run dev",
    "dev:web": "pnpm --filter @smartnotes/web run dev",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.12.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
